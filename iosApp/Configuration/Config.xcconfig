#include? "Version.xcconfig"

TEAM_ID=

PRODUCT_NAME=Nuvio
PRODUCT_BUNDLE_IDENTIFIER=com.nuvio.app.Nuvio$(TEAM_ID)

// ComposeApp's androidx.sqlite cinterop needs the system sqlite3 at link time.
// (sqlite3_load_extension, which Apple omits, is stubbed in sqlite3_load_extension_stub.c —
// a -Wl,-U escape passes the link but dyld aborts at launch.)
OTHER_LDFLAGS=$(inherited) -lsqlite3